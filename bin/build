#!/usr/bin/env bash
set -euo pipefail

IMAGE="ghcr.io/somospollo/caddy"
VERSION=$(grep -oP 'FROM caddy:\K[^-]+' "$(dirname "$0")/../Dockerfile" | head -1)

echo "Building ${IMAGE}:${VERSION} for linux/amd64,linux/arm64..."

docker buildx build \
  --platform linux/amd64,linux/arm64 \
  --provenance=false \
  --tag "${IMAGE}:${VERSION}" \
  --tag "${IMAGE}:latest" \
  --push \
  "$(dirname "$0")/.."
